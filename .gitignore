profile_default/
ipython_config.py

# pdm
.pdm.toml

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder / Rope / mypy / pyre / pytype
.spyderproject
.spyproject
.ropeproject
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Cython debug symbols
cython_debug/

# mkdocs documentation
/site

*.session
*.session-journal

/docker_folder

# =============================================================================
# TelQbot — never commit secrets, live config, or runtime data
# =============================================================================

# Live config (use config.example.yml as the template)
config.yml
config.json
**/config.yml
**/config.json
!**/config.example.yml
!**/config.example.json

# Docker runtime data — only the example template is tracked
docker/from_source/qbittorrent-bot-data/*
!docker/from_source/qbittorrent-bot-data/config.example.yml

# Non-Docker runtime data
data/config.yml
data/config.json
data/logs/

# Bot logs (may contain paths, errors, connection details)
**/logs/
*.log
*.log.*

# Environment and secret files
.env
.env.*
.envrc
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
*.secret

# Local backups you might create before pushing
*-backup.zip
*.bak
*.backup
